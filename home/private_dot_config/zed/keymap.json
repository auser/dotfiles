// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
//
// ~/.config/zed/keymap.json
// LazyVim → Zed  |  Cursor AI workflow
[
  // =============================================
  // TERMINAL — AI triggers (Cursor-style ctrl-k)
  // =============================================
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-k": "assistant::InlineAssist",
      "ctrl-i": "assistant::InlineAssist",
    },
  },

  // =============================================
  // GLOBAL — recent projects (works everywhere)
  // =============================================
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-shift-o": "projects::OpenRecent",
    },
  },

  // =============================================
  // GLOBAL TOGGLES — terminal dock, command palette
  // =============================================
  {
    "context": "Workspace || Editor || Terminal",
    "bindings": {
      "ctrl-/": "workspace::ToggleBottomDock",
      "ctrl-`": "workspace::ToggleBottomDock",
    },
  },
  {
    "context": "Workspace && not_editing",
    "bindings": {
      "space e": "workspace::ToggleLeftDock",
    },
  },

  // =============================================
  // WINDOW / PANE NAVIGATION
  // ctrl-k is freed for AI — pane-up moves to ctrl-shift-k
  // =============================================
  {
    "context": "Dock || Terminal || Editor",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-shift-k": "workspace::ActivatePaneUp",
    },
  },

  // =============================================
  // INSERT MODE
  // =============================================
  {
    "context": "Editor && vim_mode == insert && !menu",
    "bindings": {
      "j k": ["workspace::SendKeystrokes", "escape"],
      "j j": ["workspace::SendKeystrokes", "escape"],
      "ctrl-s": ["action::Sequence", ["vim::NormalBefore", "workspace::Save"]],
      // Cursor-style AI in insert mode
      "ctrl-k": "assistant::InlineAssist",
      "ctrl-l": "agent::Toggle",
    },
  },

  // =============================================
  // SCROLL + CENTER (VimControl — normal & visual)
  // NOTE: shift-g removed intentionally — it breaks dG operator
  // =============================================
  {
    "context": "VimControl && !menu",
    "bindings": {
      "ctrl-d": ["workspace::SendKeystrokes", "ctrl-d z z"],
      "ctrl-u": ["workspace::SendKeystrokes", "ctrl-u z z"],
      "n": ["workspace::SendKeystrokes", "n z z z v"],
      "shift-n": ["workspace::SendKeystrokes", "shift-n z z z v"],
      "g r": "editor::FindAllReferences",
    },
  },

  // =============================================
  // SUBWORD MOTIONS (w/b/e navigate camelCase & snake_case)
  // e.g. myVariableName → 3 stops instead of 1
  // =============================================
  {
    "context": "VimControl && !menu && vim_mode != operator",
    "bindings": {
      "w": "vim::NextSubwordStart",
      "b": "vim::PreviousSubwordStart",
      "e": "vim::NextSubwordEnd",
      "g e": "vim::PreviousSubwordEnd",
    },
  },

  // =============================================
  // SNEAK (s/S — like leap.nvim)
  // =============================================
  {
    "context": "vim_mode == normal || vim_mode == visual",
    "bindings": {
      "s": "vim::PushSneak",
      "S": "vim::PushSneakBackward",
    },
  },

  // =============================================
  // VISUAL MODE SURROUND (g s — S is taken by sneak backward)
  // =============================================
  {
    "context": "vim_mode == visual",
    "bindings": {
      "g s": "vim::PushAddSurrounds",
    },
  },

  // =============================================
  // ANY BRACKETS shortcut (cib, dib, vib etc.)
  // =============================================
  {
    "context": "vim_operator == a || vim_operator == i || vim_operator == cs",
    "bindings": {
      "b": "vim::AnyBrackets",
    },
  },

  // =============================================
  // NORMAL MODE
  // =============================================
  {
    "context": "vim_mode == normal && !menu",
    "bindings": {
      "ctrl-s": "workspace::Save",
      "shift-y": ["workspace::SendKeystrokes", "y $"],
      // Cursor AI: ctrl-k = inline edit, ctrl-l = toggle AI panel
      "ctrl-k": "assistant::InlineAssist",
      "ctrl-l": "agent::Toggle",
      // Cursor AI: ctrl-e = toggle agent layout (right dock)
      "ctrl-e": "workspace::ToggleRightDock",
    },
  },

  // =============================================
  // VISUAL MODE
  // =============================================
  {
    "context": "vim_mode == visual && !menu",
    "bindings": {
      // Cursor AI: ctrl-k = inline assist on selection
      "ctrl-k": "assistant::InlineAssist",
      // Cursor AI: ctrl-shift-l = add selection to chat (matches Cursor exactly)
      "ctrl-shift-l": "agent::AddSelectionToThread",
      "ctrl-s": [
        "action::Sequence",
        ["vim::SwitchToNormalMode", "workspace::Save"],
      ],
    },
  },

  // =============================================
  // VISUAL MODE — move lines (J/K like LazyVim)
  // =============================================
  {
    "context": "Editor && vim_mode == visual && !VimWaiting && !VimObject",
    "bindings": {
      "shift-j": "editor::MoveLineDown",
      "shift-k": "editor::MoveLineUp",
    },
  },

  // =============================================
  // NORMAL + VISUAL — LEADER BINDINGS (space as leader)
  // =============================================
  {
    "context": "Editor && VimControl && !VimWaiting && !menu",
    "bindings": {
      // --- Tab / Buffer navigation ---
      "shift-h": "pane::ActivatePreviousItem",
      "shift-l": "pane::ActivateNextItem",
      "] b": "pane::ActivateNextItem",
      "[ b": "pane::ActivatePreviousItem",

      // Tab by number (harpoon-style)
      "space 1": ["pane::ActivateItem", 0],
      "space 2": ["pane::ActivateItem", 1],
      "space 3": ["pane::ActivateItem", 2],
      "space 4": ["pane::ActivateItem", 3],
      "space 5": ["pane::ActivateItem", 4],
      "space 6": ["pane::ActivateItem", 5],
      "space 7": ["pane::ActivateItem", 6],
      "space 8": ["pane::ActivateItem", 7],
      "space 9": ["pane::ActivateItem", 8],
      "space 0": "pane::ActivateLastItem",

      // --- File / Find (space f) — Telescope equivalents ---
      "space f f": "file_finder::Toggle",
      "space space": "file_finder::Toggle",
      "space f g": "workspace::NewSearch",
      "space f r": "projects::OpenRecent",
      "space f p": "projects::OpenRecent",
      "space f n": "workspace::NewFile",

      // --- Explorer (space e) — neo-tree equivalent ---
      "space e": "workspace::ToggleLeftDock",
      "-": "project_panel::ToggleFocus",

      // --- Buffer (space b) ---
      "space b b": "pane::AlternateFile",
      "space b d": "pane::CloseActiveItem",
      "space b o": "pane::CloseOtherItems",
      "space b q": "pane::CloseAllItems",
      "space b n": "workspace::NewFile",
      "space ,": "tab_switcher::Toggle",

      // --- Search (space s) ---
      "space /": "workspace::NewSearch",
      "space s g": "workspace::NewSearch",
      "space s b": "vim::Search",
      "space s w": "buffer_search::Deploy",
      "space s W": "pane::DeploySearch",
      "space s s": "outline::Toggle",
      "space s d": "diagnostics::Deploy",

      // --- LSP & Code actions (space c) ---
      "space c a": "editor::ToggleCodeActions",
      "space c r": "editor::Rename",
      "space c f": "editor::Format",
      "space l d": "diagnostics::Deploy",
      // K = LSP hover (LazyVim default)
      "K": "editor::Hover",

      // --- Diagnostics / Trouble (space x — trouble.nvim) ---
      "space x x": "diagnostics::Deploy",
      "space x d": "editor::GoToDiagnostic",

      // --- Git (space g) ---
      "space g g": ["task::Spawn", { "task_name": "lazygit" }],
      "space g b": "git::Blame",
      "space g h d": "editor::ExpandAllDiffHunks",
      "space g h D": "git::Diff",
      "space g h r": "git::Restore",
      "space g h R": "git::RestoreFile",

      // --- Git hunk navigation ---
      "] h": "editor::GoToHunk",
      "[ h": "editor::GoToPreviousHunk",

      // --- Diagnostic navigation ---
      "] d": "editor::GoToDiagnostic",
      "[ d": "editor::GoToPreviousDiagnostic",
      "] e": "editor::GoToDiagnostic",
      "[ e": "editor::GoToPreviousDiagnostic",

      // --- Excerpt / quickfix navigation ---
      "] q": "editor::MoveToStartOfNextExcerpt",
      "[ q": "editor::MoveToStartOfExcerpt",

      // --- Window / Split (space w) ---
      "space w v": "pane::SplitRight",
      "space w s": "pane::SplitDown",
      "space -": "pane::SplitDown",
      "space |": "pane::SplitRight",
      "space w c": "pane::CloseAllItems",
      "space w d": "pane::CloseAllItems",
      "space w q": "pane::CloseActiveItem",

      // --- Terminal (space t) ---
      "space t": "workspace::ToggleBottomDock",
      "space f t": "workspace::ToggleBottomDock",

      // --- Tasks (space r — run tasks like lazygit, dev, test) ---
      "space r r": "task::Spawn",
      "space r l": ["task::Spawn", { "task_name": "lazygit" }],
      "space r d": ["task::Spawn", { "task_name": "dev (bun)" }],
      "space r t": ["task::Spawn", { "task_name": "test" }],
      "space r b": ["task::Spawn", { "task_name": "build" }],

      // --- AI Panel (space a — agent/chat panel) ---
      "space a": "workspace::ToggleRightDock",

      // --- Toggle features (space u) ---
      "space u i": "editor::ToggleInlayHints",
      "space u w": "editor::ToggleSoftWrap",

      // --- Command palette (space ; / space :) ---
      "space ;": "command_palette::Toggle",
      "space :": "command_palette::Toggle",

      // --- Markdown preview ---
      "space m p": "markdown::OpenPreview",
      "space m P": "markdown::OpenPreviewToTheSide",

      // --- Move lines (Alt+j/k like LazyVim) ---
      "alt-j": "editor::MoveLineDown",
      "alt-k": "editor::MoveLineUp",

      // --- Clear search highlights ---
      "space n": ["workspace::SendKeystrokes", ": n o h enter"],

      // --- Quit ---
      "space q q": "zed::Quit",
    },
  },

  // =============================================
  // PROJECT PANEL — file tree (like neo-tree)
  // =============================================
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "a": "project_panel::NewFile",
      "shift-a": "project_panel::NewDirectory",
      "r": "project_panel::Rename",
      "shift-r": "project_panel::Rename",
      "d": "project_panel::Delete",
      "shift-d": "project_panel::Delete",
      "x": "project_panel::Cut",
      "c": "project_panel::Copy",
      "y": "project_panel::Copy",
      "p": "project_panel::Paste",
      "q": "workspace::ToggleLeftDock",
      "space e": "workspace::ToggleLeftDock",
      ":": "command_palette::Toggle",
      "%": "project_panel::NewFile",
      "/": "project_panel::NewSearchInDirectory",
      "enter": "project_panel::OpenPermanent",
      "o": "project_panel::OpenPermanent",
      "t": "project_panel::OpenPermanent",
      "v": "project_panel::OpenPermanent",
      "escape": "project_panel::ToggleFocus",
      "h": "project_panel::CollapseSelectedEntry",
      "j": "menu::SelectNext",
      "k": "menu::SelectPrevious",
      "l": "project_panel::ExpandSelectedEntry",
      "shift-g": "menu::SelectLast",
      "g g": "menu::SelectFirst",
      "-": "project_panel::SelectParent",
      "ctrl-6": "pane::AlternateFile",
    },
  },

  // =============================================
  // GIT PANEL
  // =============================================
  {
    "context": "GitPanel",
    "bindings": {
      "q": "git_panel::Close",
    },
  },

  // =============================================
  // AI / AGENT PANEL — Cursor-style mode switching
  // shift-tab = cycle profiles (Write → Ask → Minimal)
  // ctrl-alt-p = manage profiles modal
  // ctrl-alt-/ = switch AI model
  // ctrl-shift-h = view thread history
  // =============================================
  {
    "context": "AgentPanel",
    "bindings": {
      "ctrl-\\": "workspace::ToggleRightDock",
      "ctrl-n": "agent::NewThread",
      // "ctrl-shift-h": "agent::OpenHistory",
      "ctrl-alt-p": "agent::ManageProfiles",
    },
  },

  // =============================================
  // EMPTY PANE (no file open)
  // =============================================
  {
    "context": "EmptyPane || SharedScreen",
    "bindings": {
      "space space": "file_finder::Toggle",
      "space f n": "workspace::NewFile",
      "space f p": "projects::OpenRecent",
      "space s g": "workspace::NewSearch",
      "space q q": "zed::Quit",
    },
  },

  // =============================================
  // EDITOR — restore standard shortcuts
  // ctrl-shift-l = add selection to AI chat (Cursor-style)
  // ctrl-shift-a = select all matches (moved from ctrl-shift-l)
  // =============================================
  {
    "context": "Editor && !menu",
    "bindings": {
      "ctrl-c": "editor::Copy",
      "ctrl-v": "editor::Paste",
      "ctrl-x": "editor::Cut",
      "ctrl-a": "editor::SelectAll",
      "ctrl-i": "assistant::InlineAssist",
      "ctrl-shift-l": "agent::AddSelectionToThread",
      "ctrl-shift-a": "editor::SelectAllMatches",
    },
  },
]
